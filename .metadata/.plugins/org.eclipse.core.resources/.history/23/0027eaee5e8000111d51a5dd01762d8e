package collections;

import java.util.*;

public class EmployeeVector {

    public static void main(String[] args) {

        Vector<Employee> vector = new Vector<>();

        vector.add(new Employee1(101,"Manoj"));
        vector.add(new Employee1(102,"Rahul"));
        vector.add(new Employee1(103,"Kiran"));

        System.out.println("Using Iterator");

        Iterator<Employee> itr = vector.iterator();

        while(itr.hasNext())
            System.out.println(itr.next());

        System.out.println();

        System.out.println("Using Enumeration");

        Enumeration<Employee> en = vector.elements();

        while(en.hasMoreElements())
            System.out.println(en.nextElement());
    }
}